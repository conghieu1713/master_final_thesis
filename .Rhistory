UB <- c(0.999, 0.999, 50.0)
# Ràng buộc bất phương trình: a + b < 1
ineq_fun <- function(theta_params, Z, N_c, K_c) {
return(theta_params[1] + theta_params[2])
}
# Chạy thuật toán tối ưu Rsolnp (có thể mất 1-3 phút)
cat("Đang chạy tối ưu hóa, vui lòng đợi...\n")
optim_results <- solnp(pars = init_params,
fun = dcc_midas_likelihood,
ineqfun = ineq_fun,
ineqLB = 0.001,  # a + b > 0.001
ineqUB = 0.999,  # a + b < 0.999
LB = LB,
UB = UB,
Z = Z_matrix,
N_c = N_c_window,
K_c = K_c_lags)
library(Rsolnp)
library(xts)
# ---------------------------------------------------------
# HÀM 1: Tính trọng số Beta (với w1 cố định = 1)
# ---------------------------------------------------------
beta_weight <- function(K, w2) {
k <- 1:K
w <- (1 - k/K)^(w2 - 1)
return(w / sum(w))
}
# ---------------------------------------------------------
# HÀM 2: Hàm Âm Log-Likelihood cho DCC-MIDAS tiêu chuẩn
# ---------------------------------------------------------
# theta_params = c(a, b, w2)
dcc_midas_likelihood <- function(theta_params, Z, N_c, K_c) {
a  <- theta_params[1]
b  <- theta_params[2]
w2 <- theta_params[3]
T <- nrow(Z)
LL <- 0
# Khởi tạo ma trận Q
Q <- cor(Z)
# 1. Tính chuỗi tương quan cục bộ (Local Correlation - c_t)
# Tính tương quan trong cửa sổ N_c ngày cho mỗi thời điểm t
c_t <- numeric(T)
for (t in (N_c + 1):T) {
z1 <- Z[(t - N_c):(t - 1), 1]
z2 <- Z[(t - N_c):(t - 1), 2]
# Tính tương quan, thay thế bằng 0 nếu dính lỗi NA do phương sai bằng 0
c_local <- suppressWarnings(cor(z1, z2))
if(is.na(c_local)) c_local <- 0
c_t[t] <- c_local
}
# 2. Tính tương quan dài hạn (rho_long) qua hàm MIDAS
weights <- beta_weight(K_c, w2)
rho_long <- numeric(T)
# Bắt đầu vòng lặp từ thời điểm có đủ dữ liệu trễ (N_c + K_c + 1)
start_t <- N_c + K_c + 1
for (t in start_t:T) {
# Tích chập tương quan cục bộ với trọng số Beta
rho_long[t] <- sum(weights * c_t[(t-1):(t-K_c)])
# Ép biên an toàn để ma trận luôn dương (tránh lỗi det <= 0)
rho_long[t] <- max(min(rho_long[t], 0.999), -0.999)
}
# 3. Vòng lặp cập nhật Q_t và tính hàm hợp lý
for (t in start_t:T) {
# Ma trận tương quan dài hạn tại t
R_bar <- matrix(c(1, rho_long[t],
rho_long[t], 1), nrow = 2, ncol = 2)
# Cập nhật hiệp phương sai giả Q_t
z_lag <- matrix(Z[t-1, ], ncol = 1)
Q <- (1 - a - b) * R_bar + a * (z_lag %*% t(z_lag)) + b * Q
# Chuẩn hóa Q_t thành ma trận tương quan R_t
Q_diag_inv <- diag(1 / sqrt(diag(Q)))
R_t <- Q_diag_inv %*% Q %*% Q_diag_inv
# Trích xuất dữ liệu ngày t
z_t <- matrix(Z[t, ], ncol = 1)
# Tính Det(R_t), phạt hàm mục tiêu nếu ma trận lỗi
det_R <- det(R_t)
if (det_R <= 1e-10 || is.na(det_R)) return(1e10)
# Cộng dồn hàm Log-Likelihood
term1 <- log(det_R)
term2 <- t(z_t) %*% solve(R_t) %*% z_t
LL <- LL - 0.5 * (term1 + term2)
}
return(as.numeric(-LL))
}
