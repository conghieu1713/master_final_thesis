library(Rsolnp)
library(xts)
# ---------------------------------------------------------
# HÀM 1: Tính trọng số Beta (với w1 cố định = 1)
# ---------------------------------------------------------
beta_weight <- function(K, w2) {
k <- 1:K
w <- (1 - k/K)^(w2 - 1)
return(w / sum(w))
}
# ---------------------------------------------------------
# HÀM 2: Hàm Âm Log-Likelihood cho DCC-MIDAS tiêu chuẩn
# ---------------------------------------------------------
# theta_params = c(a, b, w2)
dcc_midas_likelihood <- function(theta_params, Z, N_c, K_c) {
a  <- theta_params[1]
b  <- theta_params[2]
w2 <- theta_params[3]
T <- nrow(Z)
LL <- 0
# Khởi tạo ma trận Q
Q <- cor(Z)
# 1. Tính chuỗi tương quan cục bộ (Local Correlation - c_t)
# Tính tương quan trong cửa sổ N_c ngày cho mỗi thời điểm t
c_t <- numeric(T)
for (t in (N_c + 1):T) {
z1 <- Z[(t - N_c):(t - 1), 1]
z2 <- Z[(t - N_c):(t - 1), 2]
# Tính tương quan, thay thế bằng 0 nếu dính lỗi NA do phương sai bằng 0
c_local <- suppressWarnings(cor(z1, z2))
if(is.na(c_local)) c_local <- 0
c_t[t] <- c_local
}
# 2. Tính tương quan dài hạn (rho_long) qua hàm MIDAS
weights <- beta_weight(K_c, w2)
rho_long <- numeric(T)
# Bắt đầu vòng lặp từ thời điểm có đủ dữ liệu trễ (N_c + K_c + 1)
start_t <- N_c + K_c + 1
for (t in start_t:T) {
# Tích chập tương quan cục bộ với trọng số Beta
rho_long[t] <- sum(weights * c_t[(t-1):(t-K_c)])
# Ép biên an toàn để ma trận luôn dương (tránh lỗi det <= 0)
rho_long[t] <- max(min(rho_long[t], 0.999), -0.999)
}
# 3. Vòng lặp cập nhật Q_t và tính hàm hợp lý
for (t in start_t:T) {
# Ma trận tương quan dài hạn tại t
R_bar <- matrix(c(1, rho_long[t],
rho_long[t], 1), nrow = 2, ncol = 2)
# Cập nhật hiệp phương sai giả Q_t
z_lag <- matrix(Z[t-1, ], ncol = 1)
Q <- (1 - a - b) * R_bar + a * (z_lag %*% t(z_lag)) + b * Q
# Chuẩn hóa Q_t thành ma trận tương quan R_t
Q_diag_inv <- diag(1 / sqrt(diag(Q)))
R_t <- Q_diag_inv %*% Q %*% Q_diag_inv
# Trích xuất dữ liệu ngày t
z_t <- matrix(Z[t, ], ncol = 1)
# Tính Det(R_t), phạt hàm mục tiêu nếu ma trận lỗi
det_R <- det(R_t)
if (det_R <= 1e-10 || is.na(det_R)) return(1e10)
# Cộng dồn hàm Log-Likelihood
term1 <- log(det_R)
term2 <- t(z_t) %*% solve(R_t) %*% z_t
LL <- LL - 0.5 * (term1 + term2)
}
return(as.numeric(-LL))
}
# Đọc dữ liệu từ file
path <- "D:\\Post-graduate programme\\Final Thesis\\Model\\standardized_residuals_1.csv"
data <- read.csv(path, header = TRUE)
# Thiết lập ma trận phần dư Z_t
z_vnindex <- xts(data$VNIndex, order.by = as.Date(data$Date))
colnames(z_vnindex) <- c("VNIndex")
z_xauusd <- xts(data$XAUUSD, order.by = as.Date(data$Date))
colnames(z_xauusd) <- c("XAUUSD")
z_matrix <- as.matrix(cbind(z_vnindex, z_xauusd))
# Thiết lập cửa sổ thời gian
N_c <- 21
K_c <- 504
# Thiết lập giá trị khởi tạo
init_params <- c(0.03, 0.9, 3.0)
# Thiết lập ràng buộc (Bounds)
# Lower Bounds: a, b > 0; w2 > 1.001
LB <- c(0.001, 0.001, 1.001)
# Upper Bounds: a, b < 1; w2 < 50
UB <- c(0.999, 0.999, 50.0)
# Ràng buộc bất phương trình: a + b < 1
ineq_fun <- function(theta_params, Z, N_c, K_c) {
return(theta_params[1] + theta_params[2])
}
# Chạy thuật toán tối ưu Rsolnp (có thể mất 1-3 phút)
cat("Đang chạy tối ưu hóa, vui lòng đợi...\n")
optim_results <- solnp(pars = init_params,
fun = dcc_midas_likelihood,
ineqfun = ineq_fun,
ineqLB = 0.001,  # a + b > 0.001
ineqUB = 0.999,  # a + b < 0.999
LB = LB,
UB = UB,
Z = z_matrix,
N_c = N_c,
K_c = K_c)
# In kết quả cuối cùng
cat("\n--- KẾT QUẢ ƯỚC LƯỢNG DCC-MIDAS ---\n")
cat("Hệ số a (Cú sốc ngắn hạn):", optim_results$pars[1], "\n")
cat("Hệ số b (Quán tính ngắn hạn):", optim_results$pars[2], "\n")
cat("Hệ số w2 (Trọng số MIDAS dài hạn):", optim_results$pars[3], "\n")
cat("Log-Likelihood cực đại:", -optim_results$values[length(optim_results$values)], "\n")
# 1. Trích xuất các tham số tối ưu (Estimate)
estimates <- optim_results$pars
# 2. Lấy ma trận Hessian từ kết quả solnp
# Vì chúng ta cực tiểu hóa hàm Âm Log-Likelihood, Hessian ở đây chính là
# Ma trận Thông tin Fisher (Fisher Information Matrix)
hessian_matrix <- optim_results$hessian
# 3. Tính toán Ma trận Hiệp phương sai (Covariance Matrix) bằng cách nghịch đảo Hessian
# Dùng tryCatch để phòng trường hợp Hessian bị suy biến (do chạm giới hạn ràng buộc)
cov_matrix <- tryCatch(
solve(hessian_matrix),
error = function(e) {
warning("Ma trận Hessian không thể nghịch đảo. Sai số chuẩn có thể không chính xác.")
return(matrix(NA, nrow = 3, ncol = 3))
}
)
# 4. Tính Sai số chuẩn (Standard Error) là căn bậc hai của đường chéo ma trận hiệp phương sai
# Bỏ qua cảnh báo NaNs do căn bậc hai của số âm (nếu tối ưu bị kẹt)
std_errors <- suppressWarnings(sqrt(diag(cov_matrix)))
# 5. Tính giá trị t (t-value)
t_values <- estimates / std_errors
# 6. Tính giá trị p (p-value) sử dụng phân phối chuẩn (Standard Normal)
# do tính chất tiệm cận chuẩn của Maximum Likelihood ở cỡ mẫu lớn
p_values <- 2 * (1 - pnorm(abs(t_values)))
# 7. Tạo hàm gắn sao ý nghĩa thống kê (Significance stars)
get_stars <- function(p) {
if (is.na(p)) return("")
if (p < 0.001) return("***")
if (p < 0.01) return("**")
if (p < 0.05) return("*")
if (p < 0.1) return(".")
return(" ")
}
sig_stars <- sapply(p_values, get_stars)
# 8. Gộp tất cả vào một Data Frame để hiển thị
dcc_results_table <- data.frame(
"Estimate"   = round(estimates, 6),
"Std. Error" = round(std_errors, 6),
"t value"    = round(t_values, 4),
"Pr(>|t|)"   = signif(p_values, 4),
"Sig."       = sig_stars,
check.names  = FALSE # Giữ nguyên tên cột có ký tự đặc biệt
)
View(hessian_matrix)
View(optim_results)
View(cov_matrix)
View(optim_results)
# 1. Trích xuất các tham số tối ưu (Estimate)
estimates <- optim_results$pars
n_pars <- length(estimates)
# 2. Lấy ma trận Hessian từ kết quả solnp
# Vì chúng ta cực tiểu hóa hàm Âm Log-Likelihood, Hessian ở đây chính là
# Ma trận Thông tin Fisher (Fisher Information Matrix)
hessian_matrix <- optim_results$hessian[1:n_pars, 1:n_pars]
# 3. Tính toán Ma trận Hiệp phương sai (Covariance Matrix) bằng cách nghịch đảo Hessian
# Dùng tryCatch để phòng trường hợp Hessian bị suy biến (do chạm giới hạn ràng buộc)
cov_matrix <- tryCatch(
solve(hessian_matrix),
error = function(e) {
warning("Ma trận Hessian không thể nghịch đảo. Sai số chuẩn có thể không chính xác.")
return(matrix(NA, nrow = 3, ncol = 3))
}
)
# 4. Tính Sai số chuẩn (Standard Error) là căn bậc hai của đường chéo ma trận hiệp phương sai
# Bỏ qua cảnh báo NaNs do căn bậc hai của số âm (nếu tối ưu bị kẹt)
std_errors <- suppressWarnings(sqrt(diag(cov_matrix)))
# 5. Tính giá trị t (t-value)
t_values <- estimates / std_errors
# 6. Tính giá trị p (p-value) sử dụng phân phối chuẩn (Standard Normal)
# do tính chất tiệm cận chuẩn của Maximum Likelihood ở cỡ mẫu lớn
p_values <- 2 * (1 - pnorm(abs(t_values)))
# 7. Tạo hàm gắn sao ý nghĩa thống kê (Significance stars)
get_stars <- function(p) {
if (is.na(p)) return("")
if (p < 0.001) return("***")
if (p < 0.01) return("**")
if (p < 0.05) return("*")
if (p < 0.1) return(".")
return(" ")
}
sig_stars <- sapply(p_values, get_stars)
# 8. Gộp tất cả vào một Data Frame để hiển thị
dcc_results_table <- data.frame(
"Estimate"   = round(estimates, 6),
"Std. Error" = round(std_errors, 6),
"t value"    = round(t_values, 4),
"Pr(>|t|)"   = signif(p_values, 4),
"Sig."       = sig_stars,
check.names  = FALSE # Giữ nguyên tên cột có ký tự đặc biệt
)
# Đặt tên dòng cho các tham số
rownames(dcc_results_table) <- c("alpha (a)", "beta (b)", "theta (w2)")
# 9. In kết quả cuối cùng ra Console
cat("\n========================================================================\n")
cat("          KẾT QUẢ ƯỚC LƯỢNG: MÔ HÌNH DCC-MIDAS (CUSTOM OPTIMIZATION)      \n")
cat("========================================================================\n")
print(dcc_results_table)
cat("---\n")
cat("Signif. codes:  0 '***' 0.001 '**' 0.01 '*' 0.05 '.' 0.1 ' ' 1\n")
cat("Log-Likelihood:", round(-tail(optim_results$values, 1), 4), "\n")
cat("Số quan sát (T):", nrow(Z_matrix), "\n")
cat("Số quan sát (T):", nrow(z_matrix), "\n")
