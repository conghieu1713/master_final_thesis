cat("==========================================================\n")
cat("Note: *** p<0.01, ** p<0.05, * p<0.1\n")
# Returns an object for use if needed
return(invisible(list(estimates = results_df, stats = c(LL=ll, AIC=aic, BIC=bic))))
}
